# ─── Notion ───────────────────────────────────────────────
# API key from https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion database IDs (copy from URL: notion.so/workspace/<ID>)
NOTION_TAREAS_DB=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_PROYECTOS_DB=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NOTION_AGENTES_DB=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Notion webhook verification secret (from Notion integration dashboard)
NOTION_WEBHOOK_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OpenClaw ─────────────────────────────────────────────
# URL of the OpenClaw gateway (local or Docker)
OPENCLAW_URL=http://127.0.0.1:18789

# Bearer token configured in openclaw.json → hooks.token
OPENCLAW_TOKEN=your-secret-token-here

# ─── Server ───────────────────────────────────────────────
PORT=3500

# Optional: disable the Notion DB poller (default: true)
# POLLING_ENABLED=false

# Webhook signing secret for /webhook/notion (can be any random string)
WEBHOOK_SECRET=your-webhook-secret-here
